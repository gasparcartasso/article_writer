⸻

Step 1 → Load documents

Start with a loader that reads all .txt files from a folder.

build_graph.py

from pathlib import Path

def load_documents(folder):
    docs = {}
    for path in Path(folder).glob("*.txt"):
        docs[path.name] = path.read_text(encoding="utf-8")
    return docs

docs = load_documents("data")
for name, text in docs.items():
    print(name, "->", text[:80])

This gives a dictionary where the key is the filename and the value is the document text.

⸻

Step 2 → Extract entities and keywords

We will use spaCy for named entities and a simple TF-IDF pass for keywords.

from collections import defaultdict
import spacy
from sklearn.feature_extraction.text import TfidfVectorizer

nlp = spacy.load("en_core_web_sm")

def extract_entities(text):
    doc = nlp(text)
    entities = []
    for ent in doc.ents:
        if ent.label_ in {"ORG", "PERSON", "GPE", "PRODUCT", "EVENT"}:
            entities.append((ent.text.strip(), ent.label_))
    return list(set(entities))

def extract_keywords(docs, top_n=5):
    names = list(docs.keys())
    texts = list(docs.values())

    vectorizer = TfidfVectorizer(stop_words="english", max_features=1000)
    X = vectorizer.fit_transform(texts)
    terms = vectorizer.get_feature_names_out()

    doc_keywords = {}
    for i, name in enumerate(names):
        row = X[i].toarray().flatten()
        top_idx = row.argsort()[-top_n:][::-1]
        keywords = [terms[j] for j in top_idx if row[j] > 0]
        doc_keywords[name] = keywords

    return doc_keywords

entity_map = {name: extract_entities(text) for name, text in docs.items()}
keyword_map = extract_keywords(docs)

print(entity_map)
print(keyword_map)

At this point each document has:

• a set of named entities
• a short list of high-signal keywords

⸻

Step 3 → Build the graph

Now create the graph itself.

import networkx as nx

def build_knowledge_graph(docs, entity_map, keyword_map):
    G = nx.Graph()

    for doc_name, text in docs.items():
        G.add_node(doc_name, type="document", text=text)

        for entity_text, entity_label in entity_map[doc_name]:
            entity_id = f"entity::{entity_text}"
            G.add_node(entity_id, type="entity", label=entity_label, name=entity_text)
            G.add_edge(doc_name, entity_id, relation="mentions")

        for keyword in keyword_map[doc_name]:
            keyword_id = f"keyword::{keyword}"
            G.add_node(keyword_id, type="keyword", name=keyword)
            G.add_edge(doc_name, keyword_id, relation="has_keyword")

    return G

G = build_knowledge_graph(docs, entity_map, keyword_map)

print("Nodes:", G.number_of_nodes())
print("Edges:", G.number_of_edges())

This graph already supports useful queries.

⸻

Step 4 → Add semantic similarity between documents

Entity links are strong, but they miss cases where two documents discuss the same topic using different wording.

Add document-to-document similarity using TF-IDF cosine similarity.

from sklearn.metrics.pairwise import cosine_similarity
import numpy as np

def add_similarity_edges(G, docs, threshold=0.2):
    names = list(docs.keys())
    texts = list(docs.values())

    vectorizer = TfidfVectorizer(stop_words="english")
    X = vectorizer.fit_transform(texts)
    sim = cosine_similarity(X)

    for i in range(len(names)):
        for j in range(i + 1, len(names)):
            score = sim[i, j]
            if score >= threshold:
                G.add_edge(
                    names[i],
                    names[j],
                    relation="similar_to",
                    weight=float(score)
                )

add_similarity_edges(G, docs, threshold=0.15)

for u, v, data in G.edges(data=True):
    if data.get("relation") == "similar_to":
        print(u, "<->", v, data)

Now the graph contains both explicit links and semantic links.

That combination matters.

A graph based only on entities can be too sparse.
A graph based only on vector similarity can be too fuzzy.

Together they create a more usable structure.

⸻

Step 5 → Query the graph

Here are a few practical queries.

Find all entities mentioned by a document

def get_entities_for_document(G, doc_name):
    return [
        G.nodes[n]["name"]
        for n in G.neighbors(doc_name)
        if G.nodes[n]["type"] == "entity"
    ]

print(get_entities_for_document(G, "note1.txt"))

Find documents connected to a specific entity

def get_documents_for_entity(G, entity_name):
    entity_id = f"entity::{entity_name}"
    if entity_id not in G:
        return []
    return [
        n for n in G.neighbors(entity_id)
        if G.nodes[n]["type"] == "document"
    ]

print(get_documents_for_entity(G, "Contoso"))

Find similar documents

def get_similar_documents(G, doc_name):
    results = []
    for neighbor in G.neighbors(doc_name):
        edge = G.get_edge_data(doc_name, neighbor)
        if G.nodes[neighbor]["type"] == "document" and edge.get("relation") == "similar_to":
            results.append((neighbor, edge.get("weight", 0)))
    return sorted(results, key=lambda x: x[1], reverse=True)

print(get_similar_documents(G, "note1.txt"))

Find the most central nodes

def top_central_nodes(G, top_n=10):
    centrality = nx.degree_centrality(G)
    ranked = sorted(centrality.items(), key=lambda x: x[1], reverse=True)
    return ranked[:top_n]

for node, score in top_central_nodes(G):
    print(node, round(score, 3), G.nodes[node]["type"])

This last query is useful because central nodes often reveal:

• recurring organizations
• dominant topics
• bridge documents
• noisy terms that should be filtered out

